<div class="projects">
  <div class="row row-cols-1 row-cols-md-2">
    {%- assign selected_projects = site.projects | where: "selected", true | sort: "importance" -%}
    {%- for project in selected_projects -%}
      <div class="col mb-4">
        <div class="card h-100 hoverable">
          {% if project.img %}
            <div style="position: relative; z-index: 2; max-height: 200px; overflow: hidden;">
              {% assign entry_path = project.img | relative_url %}
              {%
                include figure.liquid
                loading="lazy"
                path=entry_path
                class="card-img-top z-depth-1"
                zoomable=true
                avoid_scaling=true
                alt=project.title
              %}
            </div>
          {% endif %}
          <div class="card-body d-flex flex-column h-100">
            <div class="d-flex justify-content-between align-items-start mb-2 flex-wrap gap-1" style="position: relative; z-index: 2;">
              <div class="d-flex flex-wrap gap-1">
                {% if project.venue %}
                  <span class="badge" style="background-color: var(--global-theme-color); color: white; font-size: 0.75em;">
                    {{ project.venue }} {{ project.year }}
                  </span>
                {% endif %}
                {% if project.category %}
                  <span class="badge" style="background-color: #6c757d; color: white; font-size: 0.75em;">
                    {{ project.category }}
                  </span>
                {% endif %}
              </div>
            </div>

            <h4 class="card-title mb-1">
              <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}" class="stretched-link">{{ project.title }}</a>
            </h4>

            <p class="card-text flex-grow-1 small">{{ project.description }}</p>

            <div class="d-flex flex-wrap gap-1 mt-3">
              {% assign arxiv_id = project.arxiv_id %}
              {% if arxiv_id %}
                <a href="https://arxiv.org/abs/{{ arxiv_id }}" class="btn btn-sm py-1 px-2" style="color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; font-size: 0.85em;" target="_blank" rel="noopener">
                  <i class="ai ai-arxiv"></i> arXiv
                </a>
              {% endif %}
              {% assign code_url = project.code_url | default: project.github %}
              {% if code_url %}
                <a href="{{ code_url }}" class="btn btn-sm py-1 px-2" style="color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; font-size: 0.85em;" target="_blank" rel="noopener">
                  <i class="fa-brands fa-github fa-sm"></i> Code
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>
