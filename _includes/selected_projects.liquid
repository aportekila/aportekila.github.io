<div class="projects" style="margin-top: 1.5rem;">
  {%- assign selected_projects = site.projects | where: "selected", true | sort: "importance" -%}
  {%- for project in selected_projects -%}
    <div class="row mb-4">
      <div class="col-md-9">
        <strong>
          <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">{{ project.title }}</a>
        </strong>
        <br>
        <em style="color: #6c757d; font-size: 0.9em;">
          {% if project.venue %}{{ project.venue }}{% if project.year %} {{ project.year }}{% endif %}{% endif %}{% if project.role %} • {{ project.role }}{% endif %}
        </em>
        <p style="margin: 0.5rem 0 0; font-size: 0.95em;">{{ project.description }}</p>
      </div>
      <div class="col-md-3 text-end" style="display: flex; flex-direction: column; justify-content: flex-start; gap: 0.5rem;">
        {% assign arxiv_id = project.arxiv_id %}
        {% if arxiv_id %}
          <a href="https://arxiv.org/abs/{{ arxiv_id }}" target="_blank" rel="noopener" style="font-size: 0.9em;">
            <i class="ai ai-arxiv"></i> arXiv
          </a>
        {% endif %}
        {% assign code_url = project.code_url | default: project.github %}
        {% if code_url %}
          <a href="{{ code_url }}" target="_blank" rel="noopener" style="font-size: 0.9em;">
            <i class="fa-brands fa-github fa-sm"></i> Code
          </a>
        {% endif %}
        <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}" style="font-size: 0.9em;">
          Details
        </a>
      </div>
    </div>
  {%- endfor -%}
</div>
